{
  "description": "📍 PROPERTY LANDMARKS CRUD TEST DATA - JSON para testes no Postman",
  "baseUrl": "http://localhost:9010/api",
  "authentication": "Bearer Token required in Authorization header",
  "note": "Replace {{propertyId}} with actual property ID from previous tests",
  
  "testData": {
    
    "createLandmark1": {
      "method": "POST",
      "url": "{{baseUrl}}/properties/{{propertyId}}/landmarks",
      "headers": {
        "Content-Type": "application/json",
        "Authorization": "Bearer {{token}}"
      },
      "body": {
        "landmarkName": "M1",
        "landmarkType": "LANDMARK",
        "coordinateX": 323456.78,
        "coordinateY": 7654321.09,
        "coordinateZ": 750.50,
        "entranceAzimuth": 0.0000,
        "exitAzimuth": 90.0000,
        "previousDistance": 0.00,
        "description": "Starting point - concrete landmark at street corner",
        "landmarkMaterial": "Concrete",
        "sequenceOrder": 1
      }
    },

    "createLandmark2": {
      "method": "POST",
