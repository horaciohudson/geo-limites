        "sequenceOrder": 6
      }
    },

    "updateLandmark": {
      "method": "PUT",
      "url": "{{baseUrl}}/properties/{{propertyId}}/landmarks/{{landmarkId}}",
      "headers": {
        "Content-Type": "application/json",
        "Authorization": "Bearer {{token}}"
      },
      "body": {
        "landmarkName": "M1-Updated",
        "landmarkType": "LANDMARK",
        "coordinateX": 323456.80,
        "coordinateY": 7654321.10,
        "coordinateZ": 750.52,
        "description": "Starting point - concrete landmark at street corner (updated coordinates)",
        "landmarkMaterial": "Reinforced concrete"
      }
    }
  },

  "landmarkTypes": {
    "description": "Available landmark types for landmarkType field",
    "types": [
      "LANDMARK",
      "VERTEX", 
      "REFERENCE_POINT"
    ]
  },

  "materialExamples": {
    "description": "Common materials for landmarkMaterial field",
    "materials": [
      "Concrete",
      "Iron pipe",
      "Steel rod",
      "Concrete with metal plate",
      "Bronze plate",
      "Stone marker",
      "Wooden post",
      "Virtual point",
      "Reinforced concrete"
    ]
  },

  "otherEndpoints": {
    "listLandmarks": {
      "method": "GET",
      "url": "{{baseUrl}}/properties/{{propertyId}}/landmarks",
      "headers": {
        "Authorization": "Bearer {{token}}"
      }
    },
    
    "deleteLandmark": {
      "method": "DELETE",
      "url": "{{baseUrl}}/properties/{{propertyId}}/landmarks/{{landmarkId}}",
      "headers": {
        "Authorization": "Bearer {{token}}"
      }
    },
    
    "deleteAllLandmarks": {
      "method": "DELETE",
      "url": "{{baseUrl}}/properties/{{propertyId}}/landmarks",
      "headers": {
        "Authorization": "Bearer {{token}}"
      }
    },
    
    "countLandmarks": {
      "method": "GET",
      "url": "{{baseUrl}}/properties/{{propertyId}}/landmarks/count",
      "headers": {
        "Authorization": "Bearer {{token}}"
      }
    }
  },

  "coordinateNotes": {
    "system": "SIRGAS 2000 / UTM zone 23S",
    "xRange": "X coordinates (Easting) typically 200,000 - 800,000",
    "yRange": "Y coordinates (Northing) typically 7,000,000 - 8,000,000", 
    "zRange": "Z coordinates (Altitude) in meters above sea level",
    "azimuthRange": "Azimuth in decimal degrees (0.0000 - 359.9999)"
  }
}