  "otherEndpoints": {
    "listBoundaries": {
      "method": "GET",
      "url": "{{baseUrl}}/properties/{{propertyId}}/boundaries",
      "headers": {
        "Authorization": "Bearer {{token}}"
      }
    },
    
    "deleteBoundary": {
      "method": "DELETE",
      "url": "{{baseUrl}}/properties/{{propertyId}}/boundaries/{{boundaryId}}",
      "headers": {
        "Authorization": "Bearer {{token}}"
      }
    },
    
    "deleteAllBoundaries": {
      "method": "DELETE",
      "url": "{{baseUrl}}/properties/{{propertyId}}/boundaries",
      "headers": {
        "Authorization": "Bearer {{token}}"
      }
