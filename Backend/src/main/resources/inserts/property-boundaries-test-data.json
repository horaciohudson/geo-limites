      "headers": {
        "Authorization": "Bearer {{token}}"
      }
    }
  },

  "measurementNotes": {
    "extension": "Extension in meters (decimal format)",
    "azimuth": "Azimuth in decimal degrees (0.0000 - 359.9999)",
    "azimuthReference": {
      "0°": "North",
      "90°": "East", 
      "180°": "South",
      "270°": "West"
    }
  },

  "testSequence": {
    "description": "Recommended test sequence",
    "steps": [
      "1. Create property first using property-test-data.json",
      "2. Copy the propertyId from response",
      "3. Replace {{propertyId}} in URLs above",
      "4. Create boundaries in sequence (North, East, South, West)",
      "5. Test list, update, and delete operations"
    ]
  }
