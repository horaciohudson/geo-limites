{
  "description": "🌍 PROPERTY BOUNDARIES CRUD TEST DATA - JSON para testes no Postman",
  "baseUrl": "http://localhost:9010/api",
  "authentication": "Bearer Token required in Authorization header",
  "note": "Replace {{propertyId}} with actual property ID from previous tests",
  
  "testData": {
    
    "createNorthBoundary": {
      "method": "POST",
      "url": "{{baseUrl}}/properties/{{propertyId}}/boundaries",
      "headers": {
        "Content-Type": "application/json",
        "Authorization": "Bearer {{token}}"
      },
      "body": {
        "direction": "NORTH",
        "extension": 15.50,
        "azimuth": 90.0000,
        "adjacentType": "STREET",
        "adjacentName": "Flowers Street",
        "adjacentDocument": "",
        "fullDescription": "Borders to the north with Flowers Street, along a straight line measuring 15.50 meters",
        "sequenceOrder": 1
      }
    },

