  "otherEndpoints": {
    "listDocuments": {
      "method": "GET",
      "url": "{{baseUrl}}/properties/{{propertyId}}/documents",
      "headers": {
        "Authorization": "Bearer {{token}}"
      }
    },
    
    "listDocumentsByType": {
      "method": "GET",
      "url": "{{baseUrl}}/properties/{{propertyId}}/documents/type/DEED",
      "headers": {
        "Authorization": "Bearer {{token}}"
      }
    },
    
    "getDocument": {
      "method": "GET",
      "url": "{{baseUrl}}/properties/{{propertyId}}/documents/{{documentId}}",
      "headers": {
        "Authorization": "Bearer {{token}}"
      }
    },
    
    "deleteDocument": {
      "method": "DELETE",
      "url": "{{baseUrl}}/properties/{{propertyId}}/documents/{{documentId}}",
      "headers": {
        "Authorization": "Bearer {{token}}"
      }
    },
    
    "deleteAllDocuments": {
      "method": "DELETE",
      "url": "{{baseUrl}}/properties/{{propertyId}}/documents",
      "headers": {
        "Authorization": "Bearer {{token}}"
      }
    },
    
    "countDocuments": {
      "method": "GET",
      "url": "{{baseUrl}}/properties/{{propertyId}}/documents/count",
      "headers": {
        "Authorization": "Bearer {{token}}"
      }
    },
    
    "getTotalFileSize": {
      "method": "GET",
      "url": "{{baseUrl}}/properties/{{propertyId}}/documents/size",
      "headers": {
        "Authorization": "Bearer {{token}}"
      }
    },
    
    "getDocumentTypes": {
      "method": "GET",
      "url": "{{baseUrl}}/properties/{{propertyId}}/documents/types",
      "headers": {
        "Authorization": "Bearer {{token}}"
      }
    }
  },

  "testSequence": {
    "description": "Recommended test sequence for documents",
    "steps": [
      "1. Create property first using property-test-data.json",
      "2. Copy the propertyId from response",
      "3. Replace {{propertyId}} in URLs above",
      "4. Create different types of documents (DEED, REGISTRATION, PLAN, etc.)",
      "5. Test list documents and filter by type",
      "6. Test get document by ID",
      "7. Test update document",
      "8. Test count and file size endpoints",
      "9. Test delete operations"
    ]
  },

  "fileUploadNotes": {
    "description": "Notes about file upload implementation",
    "currentImplementation": "This CRUD manages document metadata only",
    "fileStorage": "Actual file upload/storage would require additional endpoints",
    "recommendations": [
      "Implement separate file upload endpoint: POST /api/properties/{propertyId}/documents/{documentId}/upload",
      "Use multipart/form-data for file uploads",
      "Store files in cloud storage (AWS S3, Google Cloud, etc.)",
      "Generate secure download URLs for file access",
