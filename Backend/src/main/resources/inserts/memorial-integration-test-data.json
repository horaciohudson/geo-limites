          "landmarkType": "LANDMARK",
          "coordinateX": 325000.00,
          "coordinateY": 7650000.00,
          "coordinateZ": 800.00,
          "entranceAzimuth": 0.0000,
          "exitAzimuth": 90.0000,
          "previousDistance": 0.00,
          "description": "Starting landmark - concrete marker",
          "landmarkMaterial": "Concrete",
          "sequenceOrder": 1
        }
      },
      {
        "description": "Landmark M2 - Northeast corner",
        "method": "POST",
        "url": "{{baseUrl}}/properties/{{propertyId}}/landmarks",
        "body": {
          "landmarkName": "M2",
          "landmarkType": "LANDMARK",
          "coordinateX": 325020.00,
          "coordinateY": 7650000.00,
          "coordinateZ": 800.05,
          "entranceAzimuth": 90.0000,
          "exitAzimuth": 180.0000,
          "previousDistance": 20.00,
