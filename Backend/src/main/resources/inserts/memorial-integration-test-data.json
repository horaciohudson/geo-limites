      },
      {
        "description": "Landmark M3 - Southeast corner",
        "method": "POST",
        "url": "{{baseUrl}}/properties/{{propertyId}}/landmarks",
        "body": {
          "landmarkName": "M3",
          "landmarkType": "LANDMARK",
          "coordinateX": 325020.00,
          "coordinateY": 7649970.00,
          "coordinateZ": 799.95,
          "entranceAzimuth": 180.0000,
          "exitAzimuth": 270.0000,
          "previousDistance": 30.00,
          "description": "Southeast corner landmark",
          "landmarkMaterial": "Concrete",
          "sequenceOrder": 3
        }
      },
      {
        "description": "Landmark M4 - Southwest corner (closing)",
        "method": "POST",
        "url": "{{baseUrl}}/properties/{{propertyId}}/landmarks",
        "body": {
          "landmarkName": "M4",
          "landmarkType": "LANDMARK",
          "coordinateX": 325000.00,
          "coordinateY": 7649970.00,
          "coordinateZ": 799.98,
          "entranceAzimuth": 270.0000,
          "exitAzimuth": 0.0000,
          "previousDistance": 20.00,
          "description": "Southwest corner - closing landmark",
          "landmarkMaterial": "Concrete",
          "sequenceOrder": 4
        }
      }
    ],

    "step3_createBoundaries": [
      {
        "description": "North boundary",
        "method": "POST",
        "url": "{{baseUrl}}/properties/{{propertyId}}/boundaries",
        "body": {
          "direction": "NORTH",
          "extension": 20.00,
          "azimuth": 90.0000,
          "adjacentType": "STREET",
          "adjacentName": "Memorial Test Street",
          "fullDescription": "North boundary with Memorial Test Street, 20.00m",
          "sequenceOrder": 1
        }
      },
      {
        "description": "East boundary",
        "method": "POST",
        "url": "{{baseUrl}}/properties/{{propertyId}}/boundaries",
        "body": {
          "direction": "EAST",
          "extension": 30.00,
          "azimuth": 180.0000,
          "adjacentType": "OWNER",
