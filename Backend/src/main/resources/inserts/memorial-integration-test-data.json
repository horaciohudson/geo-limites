          "sequenceOrder": 3
        }
      },
      {
        "description": "West boundary",
        "method": "POST",
        "url": "{{baseUrl}}/properties/{{propertyId}}/boundaries",
        "body": {
          "direction": "WEST",
          "extension": 30.00,
          "azimuth": 0.0000,
          "adjacentType": "AVENUE",
          "adjacentName": "Test Avenue",
          "fullDescription": "West boundary with Test Avenue, 30.00m",
          "sequenceOrder": 4
        }
      }
    ]
  },

  "memorialGenerationTest": {
    "description": "Test memorial generation with property data",
    
    "generateMemorialWithProperty": {
      "method": "POST",
      "url": "{{baseUrl}}/memorial/generate-gpt",
      "headers": {
        "Content-Type": "application/json",
        "Authorization": "Bearer {{token}}"
      },
      "body": {
        "entities": [
          {
            "type": "LINE",
            "layer": "BOUNDARY",
            "x": 325000.00,
            "y": 7650000.00,
            "x2": 325020.00,
            "y2": 7650000.00,
            "fingerprint": "line_north_boundary"
          },
          {
            "type": "LINE", 
            "layer": "BOUNDARY",
            "x": 325020.00,
            "y": 7650000.00,
            "x2": 325020.00,
            "y2": 7649970.00,
            "fingerprint": "line_east_boundary"
          },
          {
            "type": "LINE",
            "layer": "BOUNDARY", 
            "x": 325020.00,
            "y": 7649970.00,
            "x2": 325000.00,
            "y2": 7649970.00,
            "fingerprint": "line_south_boundary"
          },
          {
            "type": "LINE",
            "layer": "BOUNDARY",
            "x": 325000.00,
            "y": 7649970.00,
            "x2": 325000.00,
            "y2": 7650000.00,
            "fingerprint": "line_west_boundary"
          }
        ],
        "fileName": "memorial-test.dxf",
        "projectName": "Memorial Integration Test Project",
        "projectDescription": "Testing integration between Property CRUD and Memorial generation",
        "standardId": "{{standardId}}",
        "propertyId": "{{propertyId}}"
      }
    }
  },

  "verificationEndpoints": {
    "description": "Endpoints to verify the complete setup",
    
    "getPropertyWithDetails": {
      "method": "GET",
      "url": "{{baseUrl}}/properties/{{propertyId}}/details",
      "headers": {
        "Authorization": "Bearer {{token}}"
      }
    },
    
    "listLandmarks": {
      "method": "GET", 
      "url": "{{baseUrl}}/properties/{{propertyId}}/landmarks",
      "headers": {
        "Authorization": "Bearer {{token}}"
      }
    },
    
    "listBoundaries": {
      "method": "GET",
      "url": "{{baseUrl}}/properties/{{propertyId}}/boundaries", 
      "headers": {
        "Authorization": "Bearer {{token}}"
      }
    }
  },

  "testInstructions": {
    "description": "Step-by-step testing instructions",
    "steps": [
      "1. First, get authentication token from /api/auth/login",
      "2. Create property using step1_createProperty",
      "3. Copy propertyId from response and replace {{propertyId}} in all URLs",
      "4. Create landmarks using step2_createLandmarks (4 requests)",
      "5. Create boundaries using step3_createBoundaries (4 requests)", 
      "6. Verify setup using verificationEndpoints",
      "7. Get standardId from /api/memorial-standards",
      "8. Replace {{standardId}} in memorial generation request",
      "9. Test memorial generation with generateMemorialWithProperty",
      "10. Verify that memorial includes property data (owner, location, coordinates)"
    ]
  },

  "expectedResults": {
    "description": "What to expect from successful integration",
    "propertyData": "Property should be created with complete owner and location info",
    "landmarks": "4 landmarks should be created with precise UTM coordinates",
    "boundaries": "4 boundaries should be created with adjacent information",
    "memorial": "Generated memorial should include real property data instead of generic placeholders",
    "coordinates": "Memorial should use actual UTM coordinates from landmarks",
    "boundaries": "Memorial should include real boundary descriptions with adjacent names"
  }
}