{
  "description": "🏗️ MEMORIAL INTEGRATION TEST DATA - JSON para testar integração com Property CRUD",
  "baseUrl": "http://localhost:9010/api",
  "authentication": "Bearer Token required in Authorization header",
  "note": "This tests the integration between Property CRUD and Memorial generation",
  
  "completePropertySetup": {
    "description": "Complete property setup for memorial generation testing",
    
    "step1_createProperty": {
      "method": "POST",
      "url": "{{baseUrl}}/properties",
      "headers": {
        "Content-Type": "application/json",
        "Authorization": "Bearer {{token}}"
      },
      "body": {
        "name": "Memorial Test Property - Lot 25",
        "internalCode": "MEM-TEST-25",
        "ownerName": "Memorial Test Owner",
        "ownerDocument": "111.222.333-44",
        "ownerIdNumber": "11.222.333-4",
        "ownerPhone": "+55 11 1111-2222",
        "ownerEmail": "memorial.test@email.com",
        "street": "Memorial Test Street",
        "number": "250",
        "neighborhood": "Test District",
        "city": "São Paulo",
        "state": "SP",
        "zipCode": "01000-000",
        "coordinateSystem": "SIRGAS 2000 / UTM zone 23S",
        "datum": "SIRGAS 2000",
        "utmZone": "23S",
        "centralMeridian": "-45°",
        "totalArea": 600.00,
        "totalPerimeter": 100.00,
